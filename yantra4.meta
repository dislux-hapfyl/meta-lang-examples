Meta [
    Title: "User‑Defined Size Yantra Shell (Fixed)"
    File:  ./user-size-yantra-shell.meta
]

; ----- Reference string for character mapping -----
reference: " !#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]_`abcdefghijklmnopqrstuvwxyz{|}~"
ref-len: count reference

; ----- Artistic symbol set (safe characters) -----
art-symbols: ".*oO@#&%+=-~|[]$"
set-size: count art-symbols

if set-size = 0 [
    write/line "Error: Symbol set is empty!"
    bye
]

; ----- Size limits -----
MIN-SIZE: 3
MAX-SIZE: 61   ; odd maximum (keeps output manageable)

; ----- Welcome -----
write/line "=== Yantra Shell with User‑Defined Size ==="
write/line "Enter a word and then an odd size (3‑61)."
write/line "Type 'quit' as the word to exit."
write/line ""

; ----- Main loop (infinite) -----
until (False) [
    ; Get word
    user-string: ask/line "Your word: "
    write/line ""

    ; Exit condition
    if any [
        user-string = "quit"
        user-string = "exit"
        user-string = ""
    ] [
        write/line "Goodbye. May your meditation be peaceful."
        bye
    ]

    ; ----- Compute hash -----
    hash: 0
    len: count user-string
    for i [1 len] [
        ch: copy cut at user-string i 1
        pos: find reference ch
        if pos [
            char-index: ref-len - (count pos) + 1
            hash: hash + char-index
        ]
    ]
    hash: hash + len   ; include length for extra uniqueness

    ; ----- Get size from user (using until instead of while) -----
    size-ok?: False
    until (
        size-str: ask/line "Yantra size (odd number 3‑61): "
        size: to whole! size-str
        either all [
            size >= MIN-SIZE
            size <= MAX-SIZE
            is-odd size
        ] [
            size-ok?: True
        ][
            write "Invalid size. Please enter an odd number between "
            write MIN-SIZE write " and " write/line MAX-SIZE
        ]
        size-ok?
    )[]

    center: (size + 1) / 2

    write "Hash: " write hash write "  |  Size: " write/line size
    write/line "Your Yantra:"
    write/line ""

    for row [1 size] [
        line: ""
        for col [1 size] [
            distance: absolute (row - center) + absolute (col - center)
            symbol-index: 1 + ( (distance + hash) // set-size )
            current-symbol: copy cut at art-symbols symbol-index 1
            line: join/with line join/with current-symbol " "
        ]
        write/line line
    ]
    write/line ""
]
